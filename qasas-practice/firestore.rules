 rules_version = '2';                                                                                                                                                                                   
  service cloud.firestore {                                                                                                                                                                              
    match /databases/{database}/documents {                                                                                                                                                              
      function isAdmin() {
        return request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
      }
                                                                                                                                                                                                         
      // --- Users (unchanged from Pass 1) ---                                                                                                                                                           
      match /users/{userId} {                                                                                                                                                                            
        allow read: if request.auth != null &&                                                                                                                                                           
                       (request.auth.uid == userId || isAdmin());                                                                                           
                                                                                                                                                                                                         
        allow create: if request.auth != null &&                                                                                                                                                         
                         request.auth.uid == userId &&                                                                                                                                                   
                         request.resource.data.role == "student" &&                                                                                                                                      
                         request.resource.data.username is string &&                                                                                                                                     
                         request.resource.data.username.size() >= 3 &&                                                                                                                                   
                         request.resource.data.username.size() <= 20;                                                                                                                                    
                                                                                                                                                                                                         
        allow update, delete: if false;                                                                                                                                                                  

        match /topicStats/{statId} {
          allow read: if request.auth != null &&
                        (request.auth.uid == userId || isAdmin());

          allow create, update: if request.auth != null &&
                                 request.auth.uid == userId &&
                                 request.resource.data.keys().hasOnly([
                                   "userId",
                                   "category",
                                   "subtopic",
                                   "attempts",
                                   "correct",
                                   "lastAttempted",
                                   "ewmaScore",
                                   "reviewIntervalDays",
                                   "nextDueAt"
                                 ]) &&
                                 request.resource.data.userId == userId &&
                                 request.resource.data.category in ["fiqh", "hadith", "arabic", "tafsir"] &&
                                 request.resource.data.subtopic is string &&
                                 statId == request.resource.data.category + "_" + request.resource.data.subtopic &&
                                 request.resource.data.attempts is int &&
                                 request.resource.data.attempts >= 1 &&
                                 request.resource.data.correct is int &&
                                 request.resource.data.correct >= 0 &&
                                 request.resource.data.correct <= request.resource.data.attempts &&
                                 request.resource.data.ewmaScore is number &&
                                 request.resource.data.ewmaScore >= 0 &&
                                 request.resource.data.ewmaScore <= 1 &&
                                 request.resource.data.reviewIntervalDays is int &&
                                 request.resource.data.reviewIntervalDays >= 1 &&
                                 request.resource.data.reviewIntervalDays <= 30 &&
                                 request.resource.data.nextDueAt is timestamp &&
                                 request.resource.data.nextDueAt > request.time &&
                                 request.resource.data.lastAttempted == request.time;

          allow delete: if false;
        }
      }                                                                                                                                                                                                  
                                                                                                                                                                                                         
      // --- Quiz results ---                                                                                                                                                                            
      match /quizResults/{resultId} {                                                                                                                                                                    
        // Anyone signed in can read results (needed for leaderboards).                                                                                                                                  
        allow read: if request.auth != null;                                                                                                                                                             
                                                                                                                                                                                                         
        // A user can create a result document for themselves only.                                                                                                                                      
        allow create: if request.auth != null &&                                                                                                                                                         
                         request.resource.data.userId == request.auth.uid &&                                                                                                                             
                         request.resource.data.username is string &&                                                                                                                                     
                         request.resource.data.mode in ["irab", "nounFeatures", "roles", "vocab", "morphology", "fiqh", "hadith", "tafsir", "review"] &&
                         request.resource.data.bankSource in ["qasas", "quran", "fiqh", "hadith", "tafsir", "mixed"] &&
                         request.resource.data.score is number &&                                                                                                                                        
                         request.resource.data.score >= 0 &&                                                                                                                                             
                         request.resource.data.total is int &&
                         request.resource.data.total >= 1 &&
                         request.resource.data.total <= 15 &&
                         request.resource.data.score <= request.resource.data.total &&
                         (
                           (request.resource.data.mode == "review" && request.resource.data.total <= 15) ||
                           (request.resource.data.mode != "review" && request.resource.data.total == 10)
                         ) &&
                         request.resource.data.durationSeconds is number &&                                                                                                                              
                         request.resource.data.durationSeconds > 0 &&                                                                                                                                    
                         request.resource.data.completedAt == request.time;                                                                                                                              
                                                                                                                                                                                                         
        // Append-only. No edits, no deletes.                                                                                                                                                            
        allow update, delete: if false;                                                                                                                                                                  
      }                                                                                                                                                                                                  

      match /answerEvents/{eventId} {
        allow read: if request.auth != null &&
                       (resource.data.userId == request.auth.uid || isAdmin());

        allow create: if request.auth != null &&
                         request.resource.data.userId == request.auth.uid &&
                         request.resource.data.username is string &&
                         request.resource.data.mode is string &&
                         request.resource.data.bankSource is string &&
                         request.resource.data.topic is string &&
                         request.resource.data.questionId is string &&
                         request.resource.data.correct is bool &&
                         request.resource.data.answeredAt == request.time;

        allow update, delete: if false;
      }

      match /weaknessProfiles/{userId} {
        allow read: if request.auth != null &&
                      (userId == request.auth.uid || isAdmin());
        allow write: if request.auth != null && userId == request.auth.uid;
      }
                                                                                                                                                                                                         
      // Default deny                                                                                                                                                                                    
      match /{document=**} {                                                                                                                                                                             
        allow read, write: if false;                                                                                                                                                                     
      }                                                                                                                                                                                                  
    }                                                                                                                                                                                                    
  }            
